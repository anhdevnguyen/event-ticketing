# .env.example — Mẫu biến môi trường cho Local Development
#
# HƯỚNG DẪN:
#   1. Sao chép file này: cp .env.example .env
#   2. Điền giá trị thật vào .env (KHÔNG commit file .env lên Git)
#   3. Chạy: docker compose up -d
#
# Xem docs/11-DEPLOYMENT.md mục 2 để biết biến nào cần thiết cho Production.

# PostgreSQL (Local Docker)
POSTGRES_DB=event_ticketing_dev
POSTGRES_USER=event_ticketing
POSTGRES_PASSWORD=event_ticketing_local_dev
POSTGRES_PORT=5432

# Backend 
BACKEND_PORT=8080

# Backend DB
# Runtime uses DATABASE_URL; Flyway can use DATABASE_URL_DIRECT for Neon direct connections.
DATABASE_URL=jdbc:postgresql://localhost:5432/event_ticketing_dev
DATABASE_URL_DIRECT=jdbc:postgresql://localhost:5432/event_ticketing_dev
DATABASE_USERNAME=event_ticketing
DATABASE_PASSWORD=event_ticketing_local_dev

# JWT — tạo secret ngẫu nhiên đủ dài (≥ 256-bit / 32 ký tự hex trở lên)
# Lệnh tạo nhanh (macOS/Linux): openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-256-bit-secret-before-running
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# CORS — domain Frontend được phép gọi API
# Local: http://localhost:5173 (Vite dev server)
# Production: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Cookie Secure flag
# false = Local dev HTTP  (phải tắt, nếu không browser sẽ không gửi cookie qua HTTP)
# true  = Production HTTPS (bật để bảo mật)
COOKIE_SECURE=false

# Spring Profile
# Để trống cho local dev (dùng log text thường, dễ đọc trên terminal)
# Đặt "production" trên Render để bật JSON structured logging
SPRING_PROFILES_ACTIVE=

# Frontend (Vite)
# Dùng trong frontend/.env (file riêng, prefix VITE_ bắt buộc để Vite expose ra client)
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws

# Oauth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
