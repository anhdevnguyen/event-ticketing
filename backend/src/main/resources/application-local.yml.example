# Copy to application-local.yml for direct local runs outside Docker Compose.
# Keep the real application-local.yml out of Git.

spring:
  datasource:
    url: ${DATABASE_URL:jdbc:postgresql://localhost:5432/event_ticketing_dev}
    username: ${DATABASE_USERNAME:event_ticketing}
    password: ${DATABASE_PASSWORD:event_ticketing_local_dev}
  flyway:
    url: ${DATABASE_URL_DIRECT:${DATABASE_URL:jdbc:postgresql://localhost:5432/event_ticketing_dev}}
    user: ${DATABASE_USERNAME:event_ticketing}
    password: ${DATABASE_PASSWORD:event_ticketing_local_dev}

cors:
  allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174}

cookie:
  secure: ${COOKIE_SECURE:false}
